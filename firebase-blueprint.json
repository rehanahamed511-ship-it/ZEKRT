{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the profile was created." }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
